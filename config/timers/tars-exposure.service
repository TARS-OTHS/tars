[Unit]
Description=T.A.R.S Public Exposure Check
After=tars-v2.service

[Service]
Type=oneshot
User=tars
Group=tars
WorkingDirectory=/opt/tars-v2
ExecStart=/opt/tars-v2/scripts/monitor-exposure.sh
StandardOutput=append:/var/log/tars-v2-security.log
StandardError=append:/var/log/tars-v2-security.log
