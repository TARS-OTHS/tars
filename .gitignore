# Artifacts and build
data/
.env
.env.*
__pycache__/
*.pyc
.venv/
*.egg-info/
dist/
.ruff_cache/
node_modules/
.claude/

# Deployment config — generated by setup.py, keep private
config/config.yaml
config/config.*.yaml
!config/config.yaml.example
config/agents.yaml
config/agents.*.yaml
!config/agents.yaml.example
config/team.json
!config/team.json.example
config/triage.yaml
!config/triage.yaml.example
config/mcp.yaml

# Secrets — never commit
config/secrets.enc
config/secrets.salt
*.key
*.pem

# Agent workspaces — contain deployment-specific identities
agents/*/CLAUDE.md
agents/*/.mcp.json
agents/*/.claude/
!agents/main/CLAUDE.md.example
