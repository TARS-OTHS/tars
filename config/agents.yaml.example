agents:
  main:
    display_name: "My Agent"
    description: "Primary agent"
    project_dir: ./agents/main
    llm:
      provider: claude_code
      model: sonnet
    tools: all
    skills: all
    routing:
      discord:
        account: main
        channels: []          # empty = all channels
        mentions: true        # only respond when @mentioned

