[Unit]
Description=T.A.R.S Public Exposure Check
After=tars.service

[Service]
Type=oneshot
Environment=TARS_HOME=/opt/tars
User=tars
Group=tars
WorkingDirectory=/opt/tars
ExecStart=/opt/tars/scripts/monitor-exposure.sh
StandardOutput=append:/var/log/tars-security.log
StandardError=append:/var/log/tars-security.log
