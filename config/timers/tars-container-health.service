[Unit]
Description=T.A.R.S Container Health Baseline Check
After=tars.service

[Service]
Type=oneshot
User=tars
Group=tars
WorkingDirectory=/opt/tars
ExecStart=/opt/tars/scripts/monitor-container-health.sh
StandardOutput=append:/var/log/tars-security.log
StandardError=append:/var/log/tars-security.log
