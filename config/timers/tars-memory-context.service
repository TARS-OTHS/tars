[Unit]
Description=T.A.R.S Memory Context Regen
After=tars-v2.service

[Service]
Type=oneshot
User=tars
Group=tars
WorkingDirectory=/opt/tars-v2
ExecStart=/opt/tars-v2/scripts/regen-memory-context.sh
StandardOutput=append:/var/log/tars-v2-context.log
StandardError=append:/var/log/tars-v2-context.log
