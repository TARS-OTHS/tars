# TARS Environment Configuration
# Generated by setup.sh — edit carefully
#
# NOTE: Claude auth, model selection, and messaging platform (Discord/Slack)
# are handled by OpenClaw. Run `openclaw setup` to configure those.
# This file only covers TARS-specific infrastructure.

# Core paths
TARS_HOME=/home/YOUR_USERNAME
OPENCLAW_DIR=${TARS_HOME}/.openclaw
SECRETS_DIR=${TARS_HOME}/.secrets
NPM_GLOBAL_BIN=${TARS_HOME}/.npm-global/bin

# Network
DOCKER_HOST_IP=172.17.0.1
AUTH_PROXY_PORT=9100
MEMORY_API_PORT=8897
EMBEDDING_PORT=8896
WEB_PROXY_PORT=8899
DASHBOARD_PORT=8765
DASHBOARD_API_PORT=8766

# OpenClaw (pinned version)
OPENCLAW_VERSION=2026.3.8

# Agent identity
AGENT_NAME=TARS
AGENT_ID=tars
AGENT_ROLE=assistant

# Owner
OWNER_NAME=
TIMEZONE=UTC

# Optional services
JOPLIN_UPSTREAM=http://127.0.0.1:41184

# Integration API keys (stored in auth-proxy vault, not here)
# These are collected by setup.sh and encrypted with age.
# To add/change: ./scripts/vault-edit.sh
# TAVILY_API_KEY=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NOTION_TOKEN=
# TRELLO_KEY=
# TRELLO_TOKEN=
